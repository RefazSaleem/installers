PYLOAD_CONF_DIR="$HOME/.pyload"
PYLOAD_STG_CONF="$PYLOAD_CONF_DIR/settings/pyload.cfg"
PYLOAD_SCRIPT_PATH="$HOME/.local/bin"
PYLOAD_SERVICE="$SERVICE_PATH/pyload.service"
PYLOAD_CADDY_CONF="$CADDY_SITES/pyload.caddy"
